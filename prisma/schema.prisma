generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String              @id @default(cuid())
  name             String
  email            String              @unique
  passwordHash     String
  avatarColor      String              @default("#d4af37")
  themeColor       String              @default("gold")
  themeMode        String              @default("dark")
  city             String?
  country          String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  mobile           String?             @unique
  username         String?             @unique
  avatarUrl        String?
  goldCoins        Int                 @default(0)
  profilePrivacy   Json                @default("{}")
  latitude         Float?
  longitude        Float?
  timeZone         String?
  gender           Gender?
  deletionOtp      AccountDeletionOtp?
  barakahLogs      BarakahLog[]
  dailyChallenges  DailyChallenge[]
  duaEntries       DuaEntry[]
  fahmResponses    FahmResponse[]
  recvFriends      Friendship[]        @relation("RecvFriendships")
  sentFriends      Friendship[]        @relation("SentFriendships")
  moodCheckIns     MoodCheckIn[]
  notifications    Notification[]
  passwordResetOtp PasswordResetOtp?
  sentPokes        Poke[]              @relation("SentPokes")
  recvPokes        Poke[]              @relation("RecvPokes")
  ruhaniahVerses   RuhaniahVerse[]
  salahRecords     SalahRecord[]
  sessions         Session[]
  taqwaPulses      TaqwaPulse[]
  fahmProfile      UserFahmProfile?
  salahDayStats    UserSalahDayStat[]
  waktSnapshot     UserWaktSnapshot?
}

model PasswordResetOtp {
  id         String   @id @default(cuid())
  userId     String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  sendCount  Int      @default(1)
  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model MoodCheckIn {
  id        String   @id @default(cuid())
  userId    String
  moodId    String
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model AccountDeletionOtp {
  id         String   @id @default(cuid())
  userId     String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  sendCount  Int      @default(1)
  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SalahRecord {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @db.Date
  prayer          Prayer
  completed       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  kind            SalahKind @default(FARD)
  unit            Int       @default(0)
  /// Sticky: set when first marked inside wakt; survives uncheck/remark.
  completedOnTime Boolean   @default(false)
  /// Prayed in Jamat (males) or Awal Wakt (females) — gender-labelled in UI.
  /// Resets to false when fard is unmarked.
  inJamat         Boolean   @default(false)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, prayer, kind, unit])
  @@index([userId, date])
  @@index([userId, date, prayer, kind, completed])
}

model Friendship {
  id        String           @id @default(cuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  friend    User             @relation("RecvFriendships", fields: [friendId], references: [id], onDelete: Cascade)
  user      User             @relation("SentFriendships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([friendId])
  @@index([userId, status])
  @@index([friendId, status])
}

model Poke {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  message    String    @default("Don't forget your salah today 🤲")
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  prayer     Prayer?
  fromUser   User      @relation("SentPokes", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User      @relation("RecvPokes", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, readAt])
  @@index([toUserId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String
  meta      Json             @default("{}")
  dedupeKey String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([userId, type, readAt])
}

model UserWaktSnapshot {
  userId           String    @id
  dateKey          String
  prayer           Prayer?
  phase            String
  salahStatus      String
  prayerLabel      String    @default("—")
  canPoke          Boolean   @default(false)
  forbiddenNow     Boolean   @default(false)
  remainingSeconds Int       @default(0)
  elapsedSeconds   Int       @default(0)
  waktStartedAt    DateTime?
  waktEndsAt       DateTime?
  waktEndLabel     String?
  timeZone         String    @default("Asia/Dhaka")
  refreshedAt      DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dateKey, phase])
  @@index([refreshedAt])
}

model UserSalahDayStat {
  userId        String
  date          DateTime @db.Date
  onTime        Int      @default(0)
  kaza          Int      @default(0)
  missed        Int      @default(0)
  pending       Int      @default(0)
  iman          Int      @default(68)
  missedPrayers Json     @default("[]")
  refreshedAt   DateTime @default(now())
  jamat         Int      @default(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
  @@index([userId, date])
}

model TaqwaPulse {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  score     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model FahmQuestion {
  id        String   @id @default(cuid())
  category  String
  text      String
  options   Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([category, active])
}

model FahmResponse {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  questionId  String
  answerIndex Int
  weight      Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, questionId])
  @@index([userId, date])
  @@index([userId, createdAt])
}

model UserFahmProfile {
  userId         String   @id
  totalQuestions Int      @default(0)
  categoryScores Json     @default("{}")
  overallQAS     Float    @default(0)
  strongest      String?
  weakest        String?
  trend          String   @default("NEW")
  updatedAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BarakahLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  timeScore   Int
  rizqScore   Int
  healthScore Int
  heartScore  Int
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model DuaEntry {
  id           String    @id @default(cuid())
  userId       String
  text         String
  category     String
  status       String    @default("WAITING")
  context      String?
  dateStarted  DateTime  @db.Date
  dateResolved DateTime? @db.Date
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
}

model RuhaniahVerse {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @db.Date
  ayahRef        String
  reflectionText String
  dawahText      String
  signals        Json
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model DailyChallenge {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  mask      Int      @default(0)
  completed Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

enum NotificationType {
  DAWAH_POKE
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  WAKT_REMINDER
  RUHANIAH_REMINDER
}

enum Prayer {
  FAJR
  DHUHR
  ASR
  MAGHRIB
  ISHA
}

enum SalahKind {
  FARD
  SUNNAH_BEFORE
  SUNNAH_AFTER
}

enum Gender {
  MALE
  FEMALE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}
