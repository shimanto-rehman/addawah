generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String?  @unique
  email        String   @unique
  mobile       String?  @unique
  passwordHash String
  avatarColor  String   @default("#d4af37")
  avatarUrl    String?
  themeColor   String   @default("gold")
  themeMode    String   @default("dark")
  city         String?
  country      String   @default("Bangladesh")
  goldCoins    Int      @default(0)
  profilePrivacy Json   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]
  salahRecords SalahRecord[]
  sentFriends  Friendship[] @relation("SentFriendships")
  recvFriends  Friendship[] @relation("RecvFriendships")
  sentPokes    Poke[]       @relation("SentPokes")
  recvPokes    Poke[]       @relation("RecvPokes")
  deletionOtp  AccountDeletionOtp?
  passwordResetOtp PasswordResetOtp?
  moodCheckIns MoodCheckIn[]
  notifications Notification[]
}

model PasswordResetOtp {
  id         String   @id @default(cuid())
  userId     String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  sendCount  Int      @default(1)
  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model MoodCheckIn {
  id        String   @id @default(cuid())
  userId    String
  moodId    String
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model AccountDeletionOtp {
  id         String   @id @default(cuid())
  userId     String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  sendCount  Int      @default(1)
  lastSentAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model SalahRecord {
  id        String    @id @default(cuid())
  userId    String
  date      DateTime  @db.Date
  prayer    Prayer
  kind      SalahKind @default(FARD)
  unit      Int       @default(0)
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, prayer, kind, unit])
  @@index([userId, date])
}

model Friendship {
  id        String           @id @default(cuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation("SentFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User             @relation("RecvFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([friendId])
}

model Poke {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  message    String    @default("Don't forget your salah today 🤲")
  prayer     Prayer?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  fromUser   User      @relation("SentPokes", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User      @relation("RecvPokes", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, readAt])
}

enum NotificationType {
  DAWAH_POKE
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  WAKT_REMINDER
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String
  meta      Json             @default("{}")
  dedupeKey String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum Prayer {
  FAJR
  DHUHR
  ASR
  MAGHRIB
  ISHA
}

enum SalahKind {
  FARD
  SUNNAH_BEFORE
  SUNNAH_AFTER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}
