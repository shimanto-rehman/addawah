# ── Required ────────────────────────────────────────────────────────────────

# Neon: use the POOLED URL for the running app (hostname contains "-pooler")
DATABASE_URL="postgresql://neondb_owner:npg_IMh9WdYGTjc5@ep-lucky-darkness-aog2dx7i-pooler.c-2.ap-southeast-1.aws.neon.tech/addawah?sslmode=require&channel_binding=require"

# Neon: use the DIRECT URL only for Prisma migrations / db push (no "-pooler" in host)
# Optional but recommended when using Neon + Vercel
DIRECT_URL="postgresql://neondb_owner:npg_IMh9WdYGTjc5@ep-lucky-darkness-aog2dx7i.c-2.ap-southeast-1.aws.neon.tech/addawah?sslmode=require&channel_binding=require"

# Your account email — used by `npm run db:seed` to link demo friends (defaults to oldest real user)
# SEED_DEV_EMAIL="you@example.com"

# Random secret for login sessions — YOU generate this (see README)
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="paste-a-long-random-string-here"

# SMTP for welcome emails after registration (optional in dev)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="Addawah <noreply@addawah.com>"

# ── Optional ────────────────────────────────────────────────────────────────

# Profile photos in production (required on Vercel — local disk is not persistent)
# Option A — Cloudinary (recommended)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_UPLOAD_PRESET=""
#
# Option B — Vercel Blob (create a Blob store in Vercel project → Storage)
# BLOB_READ_WRITE_TOKEN=""
