# ── Required ────────────────────────────────────────────────────────────────

# Neon: use the POOLED URL for the running app (hostname contains "-pooler")
DATABASE_URL="postgresql://neondb_owner:npg_IMh9WdYGTjc5@ep-lucky-darkness-aog2dx7i-pooler.c-2.ap-southeast-1.aws.neon.tech/addawah?sslmode=require&channel_binding=require"

# Neon: use the DIRECT URL only for Prisma migrations / db push (no "-pooler" in host)
# Optional but recommended when using Neon + Vercel
DIRECT_URL="postgresql://neondb_owner:npg_IMh9WdYGTjc5@ep-lucky-darkness-aog2dx7i.c-2.ap-southeast-1.aws.neon.tech/addawah?sslmode=require&channel_binding=require"

# Random secret for login sessions — YOU generate this (see README)
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="paste-a-long-random-string-here"

# Transactional email via Resend (password reset + account deletion OTP)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=""
# Sender — omit until your domain is verified in Resend (defaults to onboarding@resend.dev)
# Do NOT use *.vercel.app — Resend cannot verify Vercel preview hostnames.
# RESEND_FROM="Addawah <noreply@addawah.com>"

# SMTP fallback (optional — welcome email; used if RESEND_API_KEY is not set)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="Addawah <noreply@addawah.com>"

# ── Optional ────────────────────────────────────────────────────────────────

# Production site URL for SEO (canonical URLs, sitemap, Open Graph, JSON-LD)
# NEXT_PUBLIC_SITE_URL="https://addawah.com"

# Google Search Console verification (optional)
# GOOGLE_SITE_VERIFICATION="your-verification-token"
# Option A — Cloudinary (recommended)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_UPLOAD_PRESET=""
#
# Option B — Vercel Blob (create once in Vercel → Storage → Blob)
# If you see "already connected to the target store", the store is linked — do NOT connect again.
# Vercel sets BLOB_STORE_ID (+ OIDC) on deploy; pull local token with: vercel env pull
# BLOB_READ_WRITE_TOKEN=""
# BLOB_STORE_ID=""
